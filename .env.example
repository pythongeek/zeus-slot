# Copy this to .env for local development
# For production, set these via fly secrets or your hosting platform

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Kimi Platform OAuth (required for production)
APP_ID=your-kimi-app-id
APP_SECRET=your-kimi-app-secret
KIMI_AUTH_URL=https://platform.moonshot.cn
KIMI_OPEN_URL=https://api.moonshot.cn

# Optional
OWNER_UNION_ID=
